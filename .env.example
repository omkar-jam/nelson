# Database — replace with your real connection string.
# Local PostgreSQL example:
#   DATABASE_URL="postgresql://postgres:password@localhost:5432/nelson?schema=public"
#   DIRECT_URL="postgresql://postgres:password@localhost:5432/nelson?schema=public"
# Neon / cloud example (use the host from your provider dashboard):
#   DATABASE_URL="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require"
#   DIRECT_URL="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/nelson?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/nelson?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="artist-media"
R2_PUBLIC_URL=""
# Optional: Supabase Storage instead of R2 (use SUPABASE_URL + SUPABASE_SERVICE_KEY + SUPABASE_BUCKET)

# Artist email — contact form and new mailing list signups are sent here.
# ARTIST_EMAIL="nelson.ferreira.uk@gmail.com"

# Sender.net — all outgoing email (contact, mailing list, newsletter). Works on Render (no SMTP blocking).
# Get an API key at https://app.sender.net → Settings → API Access Tokens.
# SENDER_API_KEY="your_sender_api_key_here"
# "From" address — must match your verified domain in Sender.
# EMAIL_FROM="Nelson Ferreira <hello@yourdomain.com>"
